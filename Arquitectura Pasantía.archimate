      <element xsi:type="archimate:Assessment" name="Oportunidad: Interculturalidad en el territorio" id="id-08fbf5cb65294ab3bd2b8a15593aaea2"/>
      <element xsi:type="archimate:Assessment" name="Riesgo: Ataques Cibernéticos" id="id-7c6f1baa76d94b8f9ae96cdb11b9153a"/>
      <element xsi:type="archimate:Assessment" name="Riesgo: Robo de información sensible" id="id-3f02bdfdaafe4efd900c7d5a61fdce0a"/>
      <element xsi:type="archimate:Assessment" name="Vulnerabilidad: Datos Centralizados" id="id-cb520bf3432a4fb497334fd0270d62b3"/>
      <element xsi:type="archimate:Assessment" name="Vulnerabilidad: Información Dispersa" id="id-16a4db501bb943a798e319c851240686"/>
      <element xsi:type="archimate:Assessment" name="Riesgo: Perdida de la información" id="id-7d9e4413a7fa49d8828becdefe9171e5"/>
    </folder>
    <folder name="Principios" id="id-4a307e494dfc41dfb079bbd8b2f2700d">
      <folder name="Otros" id="id-914b39d7bacb4a679703170c3b48b714"/>
      <element xsi:type="archimate:Principle" name="Armonía Vital y Territorial" id="id-610c5590f7474d93ba54834f9e682f15">
        <documentation>Respeto a la vida, cuidado del medio ambiente y la tierra como hogar (no como recurso comercial). </documentation>
      </element>
      <element xsi:type="archimate:Principle" name="Cohesión Cultural Comunitaria" id="id-e2d84e3bbe874e7381e01d7fb4303f57">
        <documentation>Actividades culturales (música, deporte, danza) como herramientas de construcción de identidad y comunidad. </documentation>
      </element>
      <element xsi:type="archimate:Principle" name="Gobernanza Territorial Autónoma" id="id-11215fd6c9304bb590466fc88a921539">
        <documentation>Construcción de poder popular, decisión sobre el territorio y ejercicio de la interculturalidad.</documentation>
      </element>
      <element xsi:type="archimate:Principle" name="Pedagogía del Pensamiento Campesino" id="id-6d77d320a0064d6f97c4542bab5f1e2f">
        <documentation>Educación propia, recuperación de saberes, legado de Radio Sutatenza y formación para la lucha. </documentation>
      </element>
      <element xsi:type="archimate:Principle" name="La información como bien común y no propiedad individual" id="id-c16894142aa24c9a884c6a3246ef9e86"/>
    </folder>
    <folder name="Requerimientos" id="id-36906f1f36424c798eb9915e0d68efcc">
      <element xsi:type="archimate:Requirement" name="Es necesario un control de acceso a la información" id="id-9323fa60b8224b0d93d7d7c4df92a704"/>
      <element xsi:type="archimate:Requirement" name="Se requiere un acceso compartido para la Asociación" id="id-1d54accebef64c7aa8c1ce6e373a9816"/>
      <element xsi:type="archimate:Requirement" name="Se necesita documentación de la memoria histórica y cultural" id="id-09cc43b1d2d64fed9d3702c8a21f1577"/>
      <element xsi:type="archimate:Requirement" name="Se debe realizar documentación para la defensa jurídica" id="id-d9d3eb19212344f8b04646ee22622fe6"/>
      <element xsi:type="archimate:Requirement" name="Es necesario llevar a cabo Procesos de identificación y residencia territorial" id="id-e1f5246840d642d690c44c6e0801868a"/>
      <element xsi:type="archimate:Requirement" name="Se requiere reforzar enfoques de educación y procesos de integración cultural" id="id-b284485a8b854d5d9a7a3040cd67dae0"/>
    </folder>
    <folder name="Valores" id="id-795bc8ad450a416681c420ad01794d45">
      <element xsi:type="archimate:Value" name="Dignidad Campesina" id="id-9f7ab63c26964e178d8e0413ff023bdb"/>
    </folder>
    <folder name="Restricciones" id="id-fd29a948e2a3410f87d0df6199903cea">
      <element xsi:type="archimate:Constraint" name="Presupuesto" id="id-b6cb3305411c41758bd1ceab82cebbb9">
        <documentation>Recursos limitados y falta de apoyo del estado</documentation>
      </element>
      <element xsi:type="archimate:Constraint" name="Seguridad" id="id-032348ea41604762845082aa418a5b29">
        <documentation>Presencia de actores armados en el territorio</documentation>
      </element>
    </folder>
  </folder>
